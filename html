<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PokéVault | Premium Card Marketplace</title>
    <link rel="stylesheet" href="style.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

    <!-- Navigation -->
    <nav class="navbar">
        <div class="container nav-container">
            <div class="logo">
                <i class="fa-solid fa-dice-d20"></i> PokéVault
            </div>
            <div class="nav-links">
                <a href="#">Marketplace</a>
                <a href="#">Sell</a>
                <a href="#">Community</a>
            </div>
            <div class="cart-icon">
                <i class="fa-solid fa-cart-shopping"></i>
                <span id="cart-count" class="badge">0</span>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="hero">
        <div class="hero-overlay"></div>
        <div class="container hero-content">
            <h1>Pokémon Card Marketplace</h1>
            <p>Buy and Collect Rare Pokémon Cards from the World's Top Graders</p>
            
            <div class="search-container">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="search-input" placeholder="Search for Charizard, Pikachu, etc...">
            </div>
        </div>
    </header>

    <!-- Marketplace Section -->
    <section class="marketplace container">
        
        <!-- Filters & Sort -->
        <div class="controls-bar">
            <div class="filters">
                <select id="rarity-filter">
                    <option value="all">All Rarities</option>
                    <option value="Holo">Holo</option>
                    <option value="Ultra Rare">Ultra Rare</option>
                    <option value="Secret Rare">Secret Rare</option>
                    <option value="Promo">Promo</option>
                </select>
                <select id="condition-filter">
                    <option value="all">All Conditions</option>
                    <option value="PSA 10">PSA 10 (Gem Mint)</option>
                    <option value="Mint">Mint</option>
                    <option value="Near Mint">Near Mint</option>
                </select>
            </div>
            <div class="sort-options">
                <label>Sort By:</label>
                <select id="sort-select">
                    <option value="featured">Featured</option>
                    <option value="price-desc">Price: High to Low</option>
                    <option value="price-asc">Price: Low to High</option>
                </select>
            </div>
        </div>

        <!-- Card Grid -->
        <div class="card-grid" id="card-grid">
            <!-- Cards will be injected here via JS -->
        </div>

        <!-- Pagination (Visual Only) -->
        <div class="pagination">
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn"><i class="fa-solid fa-chevron-right"></i></button>
        </div>
    </section>

    <!-- Card Details Modal -->
    <div id="card-modal" class="modal">
        <div class="modal-content">
            <span class="close-modal">&times;</span>
            <div class="modal-body">
                <div class="modal-image-container">
                    <img id="modal-img" src="" alt="Card Image">
                </div>
                <div class="modal-info">
                    <div class="modal-header">
                        <h2 id="modal-name">Card Name</h2>
                        <span id="modal-rarity" class="rarity-badge">Rarity</span>
                    </div>
                    <div class="modal-meta">
                        <div class="meta-item">
                            <span class="label">Condition</span>
                            <span id="modal-condition" class="value">Mint</span>
                        </div>
                        <div class="meta-item">
                            <span class="label">Set</span>
                            <span id="modal-set" class="value">Base Set</span>
                        </div>
                        <div class="meta-item">
                            <span class="label">Year</span>
                            <span id="modal-year" class="value">1999</span>
                        </div>
                    </div>
                    <div class="modal-price-section">
                        <span class="price-label">Current Market Value</span>
                        <h3 id="modal-price" class="price">$0.00</h3>
                    </div>
                    <div class="modal-actions">
                        <button class="btn-secondary"><i class="fa-regular fa-heart"></i> Add to Wishlist</button>
                        <button class="btn-primary" id="modal-buy-btn">Buy Now</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <footer>
        <div class="container footer-content">
            <div class="footer-col">
                <h3>PokéVault</h3>
                <p>The premier destination for high-end Pokémon collectibles.</p>
            </div>
            <div class="footer-col">
                <h4>Marketplace</h4>
                <a href="#">Buy Cards</a>
                <a href="#">Sell Cards</a>
                <a href="#">Grading Services</a>
            </div>
            <div class="footer-col">
                <h4>Support</h4>
                <a href="#">Help Center</a>
                <a href="#">Authenticity Guarantee</a>
                <a href="#">Contact Us</a>
            </div>
            <div class="footer-col">
                <h4>Follow Us</h4>
                <div class="social-icons">
                    <a href="#"><i class="fa-brands fa-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-discord"></i></a>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <p>&copy; 2026 PokéVault Marketplace. All rights reserved.</p>
        </div>
    </footer>

    <script src="script.js"></script>
</body>
</html>
